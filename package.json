{
	"name": "github-release-notifier",
	"version": "1.0.0",
	"description": "Subscribe to GitHub release email notifications",
	"main": "src/index.js",
	"type": "module",
	"imports": {
		"#src/*": "./src/*"
	},
	"scripts": {
		"start": "node src/index.js",
		"dev": "nodemon src/index.js",
		"pretest": "echo \"⚠️ Vitest only (unit + integration tests). To run all tests, pass test:all.\"",
		"test": "vitest --coverage",
		"test:ci": "vitest --run --coverage --reporter dot",
		"test:unit": "vitest --run --reporter dot --coverage tests/unit",
		"test:unit:watch": "vitest --coverage tests/unit",
		"test:integration": "vitest --run --reporter dot --coverage tests/integration",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
		"lint": "eslint src tests",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"grpc": "node src/grpc/server.js",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@grpc/grpc-js": "^1.14.3",
		"@grpc/proto-loader": "^0.8.0",
		"axios": "^1.15.2",
		"better-sqlite3": "^12.9.0",
		"express": "^5.2.1",
		"http-status-codes": "^2.3.0",
		"ioredis": "^5.10.1",
		"kysely": "^0.29.0",
		"nice-grpc-common": "^2.0.3",
		"node-cron": "^4.2.1",
		"nodemailer": "^8.0.7",
		"prom-client": "^15.1.3",
		"uuid": "^14.0.0",
		"zod": "3.x"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@evilmartians/lefthook": "^2.1.6",
		"@playwright/test": "^1.60.0",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"globals": "^17.6.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.3",
		"supertest": "^7.2.2",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20",
		"pnpm": ">=9"
	}
}
