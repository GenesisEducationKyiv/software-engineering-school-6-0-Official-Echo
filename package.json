{
	"name": "github-release-notifier",
	"version": "1.0.0",
	"description": "Subscribe to GitHub release email notifications",
	"main": "src/index.js",
	"scripts": {
		"start": "node src/index.js",
		"dev": "nodemon src/index.js",
		"test": "jest --coverage",
		"lint": "eslint src tests --ext .js",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"grpc": "node src/grpc/server.js"
	},
	"dependencies": {
		"@grpc/grpc-js": "^1.14.3",
		"@grpc/proto-loader": "^0.8.0",
		"axios": "^1.15.2",
		"better-sqlite3": "^12.9.0",
		"express": "^5.2.1",
		"ioredis": "^5.10.1",
		"node-cron": "^4.2.1",
		"nodemailer": "^8.0.7",
		"prom-client": "^15.1.3",
		"uuid": "^14.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"jest": "^30.3.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.3"
	},
	"jest": {
		"testEnvironment": "node",
		"testPathIgnorePatterns": [
			"/node_modules/"
		]
	},
	"engines": {
		"node": ">=20",
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@9.1.0"
}
