{
	"name": "github-release-notifier",
	"version": "1.0.0",
	"description": "Subscribe to GitHub release email notifications",
	"main": "src/index.js",
	"scripts": {
		"start": "node src/index.js",
		"dev": "nodemon src/index.js",
		"test": "jest --coverage --forceExit",
		"lint": "eslint src tests --ext .js",
		"grpc": "node src/grpc/server.js"
	},
	"dependencies": {
		"axios": "^1.6.7",
		"better-sqlite3": "^9.4.3",
		"express": "^4.18.2",
		"node-cron": "^3.0.3",
		"nodemailer": "^6.9.9",
		"uuid": "^9.0.0",
		"ioredis": "^5.3.2",
		"prom-client": "^15.1.0",
		"@grpc/grpc-js": "^1.10.1",
		"@grpc/proto-loader": "^0.7.10"
	},
	"devDependencies": {
		"jest": "^29.7.0",
		"nodemon": "^3.1.0",
		"eslint": "^8.57.0"
	},
	"jest": {
		"testEnvironment": "node",
		"testPathIgnorePatterns": ["/node_modules/"]
	},
	"engines": {
		"node": ">=20",
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@9.1.0"
